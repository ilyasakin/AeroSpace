# Kitchen-sink i3-gaps config: rules, outputs, gaps, workspace names with colons
set $mod Mod4
set $alt Mod1
set $term kitty

gaps inner 10
gaps outer 4
gaps top 30
smart_gaps on

default_border pixel 2
hide_edge_borders both
client.focused #4c7899 #285577 #ffffff #2e9ef4 #285577

set $ws1 "1: www"
set $ws2 "2: code"

workspace $ws1 output DP-1
workspace $ws2 output primary

bindsym $mod+Return exec $term
bindsym $alt+Tab workspace back_and_forth
bindsym $mod+minus resize shrink width 50
bindsym $mod+equal resize grow width 50
bindsym $mod+p sticky toggle
bindsym $mod+m move workspace to output right
bindsym $mod+n move container to output next
bindsym $mod+c move position center
bindsym $mod+g fullscreen toggle; floating toggle

for_window [class="firefox"] move to workspace $ws1
for_window [class="kitty" title="scratch"] floating enable, resize set 1200 800
for_window [window_role="pop-up"] floating enable
for_window [class="Spotify"] sticky enable
assign [class="Slack"] → workspace number 3
assign [class="discord"] 4

exec_always --no-startup-id picom -b
focus_follows_mouse yes
workspace_layout tabbed
workspace_auto_back_and_forth yes
